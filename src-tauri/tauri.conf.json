{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Task Tracker",
  "version": "0.1.0",
  "identifier": "com.tasktracker.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Task Tracker",
        "url": "index.html",
        "width": 960,
        "height": 680,
        "minWidth": 720,
        "minHeight": 480,
        "visible": true,
        "resizable": true
      },
      {
        "label": "applet",
        "title": "Quick Add",
        "url": "applet.html",
        "width": 380,
        "height": 480,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "focus": true
      },
      {
        "label": "settings",
        "title": "Settings",
        "url": "settings.html",
        "width": 560,
        "height": 420,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
